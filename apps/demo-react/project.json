{
  "name": "demo-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/demo-react/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/demo-react"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "demo-react:build",
        "port": 12139
      },
      "configurations": {
        "development": {
          "buildTarget": "demo-react:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "demo-react:build:production",
          "hmr": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "apps/demo-react/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/apps/demo-react"
      ],
      "options": {
        "jestConfig": "apps/demo-react/jest.config.js",
        "passWithNoTests": true
      }
    },
    "preview": {
      "dependsOn": [
        "build"
      ],
      "executor": "@nx/vite:preview-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "demo-react:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "demo-react:build:development"
        },
        "production": {
          "buildTarget": "demo-react:build:production"
        }
      }
    }
  }
}
