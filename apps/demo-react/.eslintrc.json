{
  "extends": [
    "plugin:@nx/eslint-plugin/react",
    "../../.eslintrc.json"
  ],
  "ignorePatterns": [
    "!**/*",
    "**/vite.config.*.timestamp*"
  ],
  "overrides": [
    {
      "files": [
        "*.ts",
        "*.tsx",
        "*.js",
        "*.jsx"
      ],
      "rules": {
        "@typescript-eslint/no-non-null-assertion": "off"
      }
    },
    {
      "files": [
        "*.ts",
        "*.tsx"
      ],
      "rules": {}
    },
    {
      "files": [
        "*.js",
        "*.jsx"
      ],
      "rules": {}
    }
  ]
}
